{
  "$schema": "https://opencode.ai/config.json",

  "default_agent": "plan",
  "autoupdate": false,

  "enabled_providers": ["litellm"],
  "provider": {
   "litellm": {
      // "npm": "@ai-sdk/openai",  // doesn't work
      "npm": "@ai-sdk/openai-compatible",
      "name": "litellm",
      "options": {
        "baseURL": "https://mithras.duckdns.org:4001/v1",
        "apiKey": "{env:LITELLM_API_KEY}",
        "litellmProxy": true,
      },
      "models": {
        "Qwen3.5-27B": {
          "name": "Qwen3.5-27B",
          "limit": {
            "context": 175000,
            "output": 65536,
          },
          "options": {
              "temperature": 0.6,
              "presence_penalty": 0.0
          },
         "variants": {
            "coding": {
              "temperature": 0.6,
              "presence_penalty": 0.0
            },
            "general": {
              "temperature": 1.0,
              "presence_penalty": 1.5
            }
          },
        },
        "qwen36-35": {
          "name": "qwen36-35",
          "limit": {
            "context": 262144,
            "output": 65536
          },
          "options": {
            "temperature": 0.6,
            "presence_penalty": 0.0
          },
          "variants": {
            "coding": {
              "temperature": 0.6,
              "presence_penalty": 0.0
            },
            "general": {
              "temperature": 1.0,
              "presence_penalty": 1.5
            }
          },
        },
       },
    },
  },
  "model": "litellm/Qwen3.5-27B",

  "mcp": {
    "linkedin": {
      "type": "local",
      "command": ["uvx", "linkedin-scraper-mcp", "--transport", "stdio"],
      "timeout": 60000,
      "enabled": false
    }
    // "perplexica": {
    //   "type": "local",
    //   "timeout": 300000,
    //   "enabled": false,
    //   "command": ["uvx", "perplexica-mcp", "stdio"],
    //   "environment": {
    //     "PERPLEXICA_BACKEND_URL": "http://192.168.0.6:3004/api/search",
    //     "PERPLEXICA_CHAT_MODEL_PROVIDER": "gpt_oss_120",
    //     "PERPLEXICA_CHAT_MODEL_NAME": "gpt_oss_120",
    //     "PERPLEXICA_EMBEDDING_MODEL_PROVIDER": "Transformers",
    //     "PERPLEXICA_EMBEDDING_MODEL_NAME": "all-MiniLM-L6-v2"
    //   }
    // }
  },

  "permission": {
    "websearch": "allow",
    "context7": "allow",
    "grep_app": "allow",
  },

  "plugin": [
    // https://github.com/Opencode-DCP/opencode-dynamic-context-pruning
    "file:///usr/local/bin/bun/install/global/node_modules/@tarquinen/opencode-dcp/dist/index.js",
    // https://github.com/alvinunreal/oh-my-opencode-slim
    // "file:///usr/local/bin/bun/install/global/node_modules/oh-my-opencode-slim/dist/index.js"
  ],
  
  "agent": {
    "council": {
      "disable": true,
    },
  },
}
